{
  "name": "@jeremysnr/snug",
  "version": "0.1.1",
  "description": "Fit prioritised content into a token budget. Zero dependencies.",
  "keywords": [
    "llm",
    "tokens",
    "context-window",
    "budget",
    "priority"
  ],
  "license": "MIT",
  "author": "Jeremy Smith",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeremySNR/snug.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "node node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build",
    "demo": "npx tsx examples/demo.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0"
  }
}
